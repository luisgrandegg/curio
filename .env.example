# Curio environment variables. Copy to .env and fill in. NEVER commit .env.

# --- LiveKit (WebRTC infra) ---
LIVEKIT_URL=wss://<project>.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Provider API keys ---
GOOGLE_API_KEY=
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=

# --- Provider selection (with defaults) ---
STT_PROVIDER=deepgram
LLM_PROVIDER=google
LLM_MODEL=gemini-2.5-flash
TTS_PROVIDER=cartesia
TTS_VOICE=
TTS_MODEL=sonic-2
TTS_DEFAULT_SPEED=0.9
# VISION_PROVIDER=google needs GOOGLE_API_KEY. Use `stub` for offline dev
# (canned lessons, no key) — never enable `stub` in production.
VISION_PROVIDER=google
VISION_MODEL=gemini-2.5-flash

# --- apps/api ---
PORT=3001
JWT_SECRET=dev-only-change-me
MOCK_PARENT_EMAIL=parent@curio.local
MOCK_PARENT_PASSWORD=demo1234
CORS_ORIGIN=http://localhost:3000

# --- apps/web ---
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_LIVEKIT_URL=wss://<project>.livekit.cloud

# --- apps/agent ---
API_BASE_URL=http://localhost:3001
